# Database (PostgreSQL)
# ローカル開発: postgresql://postgres:postgres@localhost:5432/naoru
# Vercel: Vercel Postgres / Neon / Supabase の接続URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naoru"
# Prisma推奨: Prisma Accelerate または接続プール経由のURL
# DIRECT_URL="postgresql://..."

# Meta Marketing API
# 詳しいトークン取得手順は docs/meta-ads-setup.md 参照
# META_AD_ACCOUNT_ID は "act_" プレフィックスあり/なし両方OK（内部で正規化）
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""

# TikTok Ads API (Phase 2)
TIKTOK_APP_ID=""
TIKTOK_APP_SECRET=""
TIKTOK_ACCESS_TOKEN=""
TIKTOK_ADVERTISER_ID=""

# App
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
